-- Product category growth analysis

-- top 5 fastest growing categories: Jun-Aug 2018 vs Mar-May 2018
-- categories with less than 10 prior orders excluded to avoid misleading % jumps
WITH category_quarterly_stats AS (
    SELECT 
        t.product_category_name_english AS category,
        -- Jun 2018 - Aug 2018
        COUNT(CASE WHEN o.order_purchase_timestamp >= '2018-06-01' THEN 1 END) AS recent_orders,
        -- Mar 2018 - May 2018
        COUNT(CASE WHEN o.order_purchase_timestamp >= '2018-03-01' 
                   AND o.order_purchase_timestamp < '2018-06-01' THEN 1 END) AS prior_orders
    FROM orders o
    JOIN order_items oi ON o.order_id = oi.order_id
    JOIN products p ON oi.product_id = p.product_id
    JOIN product_category_name_translation t ON p.product_category_name = t.product_category_name
    WHERE o.order_status = 'delivered'
    GROUP BY t.product_category_name_english
)
SELECT 
    category,
    prior_orders,
    recent_orders,
    ROUND((recent_orders - prior_orders)::numeric / NULLIF(prior_orders, 0), 2) AS growth_rate
FROM category_quarterly_stats
WHERE prior_orders > 10
ORDER BY growth_rate DESC
LIMIT 5;
